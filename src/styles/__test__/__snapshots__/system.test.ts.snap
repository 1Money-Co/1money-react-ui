    box-shadow: var(--om-shadow-1, 0 1px 3px rgba(0, 0, 0, 0.12));
  }
  .om-sm-shadow-2 {
    box-shadow: var(--om-shadow-2, 0 3px 6px rgba(0, 0, 0, 0.16));
  }
  .om-sm-shadow-3 {
    box-shadow: var(--om-shadow-3, 0 10px 20px rgba(0, 0, 0, 0.19));
  }
}"
`;
